	</docu>	
~]]></Comment><ReturnType>ULINT</ReturnType><ReturnBitSize>64</ReturnBitSize><Local><Name>Identity</Name><Type>ULINT</Type><BitSize>64</BitSize></Local><Properties><Property><Name>property</Name></Property></Properties></Method><Properties><Property><Name>PouType</Name><Value>FunctionBlock</Value></Property></Properties></DataType><DataType><Name GUID="{18071995-0000-0000-0000-000000000041}" TcBaseType="true" HideSubItems="true" CName="AmsNetId">AMSNETID</Name><BitSize>48</BitSize><BaseType GUID="{18071995-0000-0000-0000-000000000001}">BYTE</BaseType><ArrayInfo><LBound>0</LBound><Elements>6</Elements></ArrayInfo><Format><Printf>%d.%d.%d.%d.%d.%d</Printf><Parameter>[0]</Parameter><Parameter>[1]</Parameter><Parameter>[2]</Parameter><Parameter>[3]</Parameter><Parameter>[4]</Parameter><Parameter>[5]</Parameter></Format></DataType><DataType><Name GUID="{18071995-0000-0000-0000-000000000042}" TcBaseType="true" CName="AmsAddr">AMSADDR</Name><BitSize>64</BitSize><SubItem><Name>netId</Name><Type GUID="{18071995-0000-0000-0000-000000000041}">AMSNETID</Type><BitSize>48</BitSize><BitOffs>0</BitOffs></SubItem><SubItem><Name>port</Name><Type GUID="{18071995-0000-0000-0000-000000000004}">WORD</Type><BitSize>16</BitSize><BitOffs>48</BitOffs></SubItem><Format><Printf>%d.%d.%d.%d.%d.%d:%d</Printf><Parameter>.netId[0]</Parameter><Parameter>.netId[1]</Parameter><Parameter>.netId[2]</Parameter><Parameter>.netId[3]</Parameter><Parameter>.netId[4]</Parameter><Parameter>.netId[5]</Parameter><Parameter>.port</Parameter></Format><Format Name="Iec"><Printf>(netId:=[%d.%d.%d.%d.%d.%d], port :=%d)</Printf><Parameter>.netId[0]</Parameter><Parameter>.netId[1]</Parameter><Parameter>.netId[2]</Parameter><Parameter>.netId[3]</Parameter><Parameter>.netId[4]</Parameter><Parameter>.netId[5]</Parameter><Parameter>.port</Parameter></Format></DataType><DataType><Name Namespace="TcoCore">ITcoComponent</Name><BitSize>32</BitSize><ExtendsType Namespace="TcoCore">ITcoObject</ExtendsType><Properties><Property>