~]]></Comment></Method><Method><Name>CheckIfIsInServiceMode</Name><Local><Name>_myContextCycleCount</Name><Type>ULINT</Type><BitSize>64</BitSize></Local></Method><Method><Name>__getIsService</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Gets whether the component is in serviceable state. Serviceable state is when `Service` method is called cyclicaly.   
		</summary>			
	</docu>	
~]]></Comment><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Local><Name>IsService</Name><Type>BOOL</Type><BitSize>8</BitSize></Local><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>Restore</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Restores this instance to the Ready state. Can be called explicitly or from within one of the restore mechanisms.	
		</summary>			
	</docu>	
~]]></Comment><ReturnType Namespace="TcoCore">ITcoRestorable</ReturnType><ReturnBitSize>32</ReturnBitSize></Method><Method><Name>ServiceMode</Name><Comment><![CDATA[~
	<docu>
		<summary>
		    Custom service (manual, maintenance) logic.
			This method must be implemented in derived class.
		</summary>			
	</docu>	
~]]></Comment></Method><Properties><Property><Name>PouType</Name><Value>FunctionBlock</Value></Property></Properties></DataType><DataType><Name Namespace="TcoIo">TcoEthercatMasterDeviceState</Name><BitSize>104</BitSize><SubItem><Name>LinkError</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>0</BitOffs></SubItem><SubItem><Name>IOLockedAfterLinkError</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>8</BitOffs></SubItem><SubItem><Name>LinkErrorRedundancyAdapter</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>16</BitOffs></SubItem><SubItem><Name>MissingOneFrame</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>24</BitOffs></SubItem><SubItem><Name>OutOfSendResources</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>32</BitOffs></SubItem><SubItem><Name>WatchdogTriggered</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>40</BitOffs></SubItem><SubItem><Name>EthernetDriverNotFound</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>48</BitOffs></SubItem><SubItem><Name>IOResetActive</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>56</BitOffs></SubItem><SubItem><Name>AtLeastOneDeviceInInitState</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>64</BitOffs></SubItem><SubItem><Name>AtLeastOneDeviceInPreOpState</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>72</BitOffs></SubItem><SubItem><Name>AtLeastOneDeviceInSafeOpState</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>80</BitOffs></SubItem><SubItem><Name>AtLeastOneDeviceIndicatesAnErrorState</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>88</BitOffs></SubItem><SubItem><Name>DcNotInSync</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>96</BitOffs></SubItem></DataType><DataType><Name Namespace="TcoIo">ITcoEthercatMasterDevice</Name><BitSize>32</BitSize><ExtendsType GUID="{18071995-0000-0000-0000-000000000018}">PVOID</ExtendsType><Method><Name>__getAllDataValid</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getDeviceHasSomeIssue</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getSomeDataInvalid</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getSomeSyncUnitHasSomeIssue</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getState</Name><ReturnType Namespace="TcoIo">TcoEthercatMasterDeviceState</ReturnType><ReturnBitSize>104</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method></DataType><DataType><Name Namespace="TcoIo">SyncUnitTaskBase_FCD3CBF3</Name></DataType><DataType><Name Namespace="TcoIo">WcState_0B2B16F9</Name><BitSize>8</BitSize><SubItem><Name>WcState</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>0</BitOffs></SubItem><Properties><Property><Name>GeneratedUsingTerminal: EL2809-0000-0018</Name></Property></Properties></DataType><DataType><Name Namespace="TcoIo">InfoData_8649EEEB</Name><BitSize>64</BitSize><SubItem><Name>ObjectId</Name><Type>DWORD</Type><BitSize>32</BitSize><BitOffs>0</BitOffs></SubItem><SubItem><Name>State</Name><Type>UINT</Type><BitSize>16</BitSize><BitOffs>32</BitOffs></SubItem><SubItem><Name>SlaveCount</Name><Type>UINT</Type><BitSize>16</BitSize><BitOffs>48</BitOffs></SubItem><Properties><Property><Name>GeneratedUsingTerminal: IODEVICETYPE_ETHERCATPROT</Name></Property></Properties></DataType><DataType><Name Namespace="TcoIo">SyncUnitTask_AB2F5079</Name><BitSize>96</BitSize><ExtendsType Namespace="TcoIo">SyncUnitTaskBase_FCD3CBF3</ExtendsType><SubItem><Name>WcState</Name><Type Namespace="TcoIo">WcState_0B2B16F9</Type><BitSize>8</BitSize><BitOffs>0</BitOffs></SubItem><SubItem><Name>InfoData</Name><Type Namespace="TcoIo">InfoData_8649EEEB</Type><BitSize>64</BitSize><BitOffs>32</BitOffs></SubItem><Properties><Property><Name>GeneratedUsingTerminal: IODEVICETYPE_ETHERCATPROT</Name></Property></Properties></DataType><DataType><Name Namespace="TcoIo">SyncUnitState</Name><BitSize>104</BitSize><SubItem><Name>AtLeastOneSlaveInInitState</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>0</BitOffs></SubItem><SubItem><Name>AtLeastOneSlaveInPreopState</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>8</BitOffs></SubItem><SubItem><Name>AtLeastOneSlaveInBootState</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>16</BitOffs></SubItem><SubItem><Name>AtLeastOneSlaveInSafeOpState</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>24</BitOffs></SubItem><SubItem><Name>AtLeastOneSlaveInOpState</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>32</BitOffs></SubItem><SubItem><Name>AtLeastOneSlaveSignalsError</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>40</BitOffs></SubItem><SubItem><Name>InvalidVendoridOrProductcodeRead</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>48</BitOffs></SubItem><SubItem><Name>InitializationErrorOccurred</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>56</BitOffs></SubItem><SubItem><Name>AtLeastOneSlaveDisabled</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>64</BitOffs></SubItem><SubItem><Name>AtLeastOneSlaveNotPresent</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>72</BitOffs></SubItem><SubItem><Name>AtLeastOneSlaveSignalsLinkError</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>80</BitOffs></SubItem><SubItem><Name>AtLeastOneSlaveSignalsMissingLink</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>88</BitOffs></SubItem><SubItem><Name>AtLeastOneSlaveSignalsUnexpectedLink</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>96</BitOffs></SubItem></DataType><DataType><Name Namespace="TcoIo">Inputs_A65FACA4</Name><BitSize>80</BitSize><SubItem><Name>SlaveCount</Name><Type>UINT</Type><BitSize>16</BitSize><BitOffs>0</BitOffs></SubItem><SubItem><Name>DevState</Name><Type>UINT</Type><BitSize>16</BitSize><BitOffs>16</BitOffs></SubItem><SubItem><Name>Frm0State</Name><Type>UINT</Type><BitSize>16</BitSize><BitOffs>32</BitOffs></SubItem><SubItem><Name>Frm0WcState</Name><Type>UINT</Type><BitSize>16</BitSize><BitOffs>48</BitOffs></SubItem><SubItem><Name>Frm0InputToggle</Name><Type>UINT</Type><BitSize>16</BitSize><BitOffs>64</BitOffs></SubItem><Properties><Property><Name>GeneratedUsingTerminal: IODEVICETYPE_ETHERCATPROT</Name></Property></Properties></DataType><DataType><Name Namespace="TcoIo">TcoAmsNetId</Name><BitSize>48</BitSize><SubItem><Name>netId</Name><Type>BYTE</Type><ArrayInfo><LBound>0</LBound><Elements>6</Elements></ArrayInfo><BitSize>48</BitSize><BitOffs>0</BitOffs></SubItem></DataType><DataType><Name Namespace="TcoIo">InfoData_84133AC9</Name><BitSize>256</BitSize><SubItem><Name>ChangeCount</Name><Type>UINT</Type><BitSize>16</BitSize><BitOffs>0</BitOffs></SubItem><SubItem><Name>DevId</Name><Type>UINT</Type><BitSize>16</BitSize><BitOffs>16</BitOffs></SubItem><SubItem><Name>AmsNetId</Name><Type Namespace="TcoIo">TcoAmsNetId</Type><BitSize>48</BitSize><BitOffs>32</BitOffs></SubItem><SubItem><Name>CfgSlaveCount</Name><Type>UINT</Type><BitSize>16</BitSize><BitOffs>80</BitOffs></SubItem><SubItem><Name>DcToTcTimeOffset</Name><Type>LINT</Type><BitSize>64</BitSize><BitOffs>128</BitOffs></SubItem><SubItem><Name>DcToExtTimeOffset</Name><Type>LINT</Type><BitSize>64</BitSize><BitOffs>192</BitOffs></SubItem><Properties><Property><Name>GeneratedUsingTerminal: IODEVICETYPE_ETHERCATPROT</Name></Property></Properties></DataType><DataType><Name Namespace="TcoCore">ITcoTaskStatus</Name><BitSize>32</BitSize><ExtendsType GUID="{18071995-0000-0000-0000-000000000018}">PVOID</ExtendsType><Method><Name>__getBusy</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getDone</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getError</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method></DataType><DataType><Name Namespace="TcoCore">ITcoTask</Name><BitSize>32</BitSize><ExtendsType Namespace="TcoCore">ITcoObject</ExtendsType><Method><Name>__getBusy</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getDone</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getError</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>Abort</Name></Method><Method><Name>Invoke</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Use to start the execution of the task. The starting is possible from Ready state.
			<para>Moreover it is also possible to start the task again from Done state by performing the '''rising edge''' of the calling of the Invoke() method.</para>
			<p>Analogously to the xExecute signal of the <a href="https://plcopen.org/sites/default/files/downloads/creating_plcopen_compliant_function_block_libraries.pdf" title="Title"> PLCopen </a> motion function blocks.</p>			
		</summary>			
	</docu>	
~]]></Comment><ReturnType Namespace="TcoCore">ITcoTaskStatus</ReturnType><ReturnBitSize>32</ReturnBitSize></Method><Properties><Property><Name>TcPlcInterfaceId</Name><Value>970</Value></Property></Properties></DataType><DataType><Name Namespace="TcoCore">ITcoObjectRestorer</Name><BitSize>32</BitSize><ExtendsType GUID="{18071995-0000-0000-0000-000000000018}">PVOID</ExtendsType><Method><Name>RestoreObject</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Ensures calling the <c>Restore()</c> method on the object entered.	
			<para>
				<example>
				<note type="Example">
				<para>
					Possibility to use the fluent syntax.
				</para>
					<code>ChangeState(newState).RestoreObject(myFirstChildObject).RestoreObject(mySecondChildObject);</code>
				 </note>
				</example>
			</para>		
		</summary>			
	</docu>	
~]]></Comment><ReturnType Namespace="TcoCore">ITcoObjectRestorer</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>Obj</Name><Type Namespace="TcoCore">ITcoRestorable</Type><BitSize>32</BitSize></Parameter></Method></DataType><DataType><Name Namespace="TcoCore">ITcoState</Name><BitSize>32</BitSize><ExtendsType Namespace="TcoCore">ITcoObject</ExtendsType><Method><Name>__getIsAutoRestoreEnabled</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getLastStateChangeCycle</Name><ReturnType>ULINT</ReturnType><ReturnBitSize>64</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getState</Name><ReturnType>INT</ReturnType><ReturnBitSize>16</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>RestoreObject</Name><ReturnType Namespace="TcoCore">ITcoObjectRestorer</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>Obj</Name><Type Namespace="TcoCore">ITcoRestorable</Type><BitSize>32</BitSize></Parameter></Method></DataType><DataType><Name Namespace="TcoCore">ITcoServiceable</Name><BitSize>32</BitSize><ExtendsType GUID="{18071995-0000-0000-0000-000000000018}">PVOID</ExtendsType><Method><Name>__getIsService</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>Service</Name></Method></DataType><DataType><Name Namespace="TcoCore">eTaskState</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Describes the state of the respective task.
		</summary>				
	</docu>	
~]]></Comment><BitSize>16</BitSize><BaseType>INT</BaseType><EnumInfo><Text>Ready</Text><Enum>0</Enum><Comment><![CDATA[~
	<docu>
		<summary>
			Task is in Ready state, the Execute() method returns FALSE. 
			Task can be started by calling the Invoke() method. 
		</summary>				
	</docu>	
~]]></Comment></EnumInfo><EnumInfo><Text>Requested</Text><Enum>10</Enum><Comment><![CDATA[~
	<docu>
		<summary>
			Task is in Requested state, if Invoke() method has been called and the Execute() method has not been called yet. The first following call of the method Execute() 
			change the task state to Executing and returns TRUE, until Done or Error state is reached.
		</summary>				
	</docu>	
~]]></Comment></EnumInfo><EnumInfo><Text>Busy</Text><Enum>20</Enum><Comment><![CDATA[~
	<docu>
		<summary>
			When the task is in Busy state, Execute() method returns TRUE. Leaving this state is possible as follows:
			<para>1.) By calling the Abort() task gets into the Idle state.</para>
			<para>2.) By calling the DoneWhen(true) task gets into the Done state.</para>
			<para>3.) By calling the Restore() task gets into the Idle state.</para>
			<para>4.) By calling the ThrowWhen(true) task gets into the Error state.</para>
		</summary>				
	</docu>	
~]]></Comment></EnumInfo><EnumInfo><Text>Error</Text><Enum>30</Enum><Comment><![CDATA[~
	<docu>
		<summary>
			Task is in Error state. To be able to start the task again the error state has to be reseted by calling the Restore() method.
		</summary>				
	</docu>	
~]]></Comment></EnumInfo><EnumInfo><Text>Done</Text><Enum>40</Enum><Comment><![CDATA[~
	<docu>
		<summary>
			Task is in Done state, Execute() method returns FALSE. To be able to start the task again '''rising edge''' of the calling of the Invoke() method needs to be performed.
			<p>Analogously to the xExecute signal of the <a href="https://plcopen.org/sites/default/files/downloads/creating_plcopen_compliant_function_block_libraries.pdf" title="Title"> PLCopen </a> motion function blocks.</p>
		</summary>				
	</docu>	
~]]></Comment></EnumInfo><Properties><Property><Name>qualified_only</Name></Property><Property><Name>strict</Name></Property></Properties></DataType><DataType><Name Namespace="TcoCore">TcoTask</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Provides basic task execution. Task is started by calling the <see cref="PlcDocu.TcoCore.TcoTask.Invoke()"/> method. 
			The  <see cref="PlcDocu.TcoCore.TcoTask.Execute()"/> method returns true, until the task is `Done`.
			<para>
				To get the actual state of the task, 
				<see cref="PlcDocu.TcoCore.TcoTask.Ready"/>, 
				<see cref="PlcDocu.TcoCore.TcoTask.Busy"/>, 
				<see cref="PlcDocu.TcoCore.TcoTask.Error"/> 
				and <see cref="PlcDocu.TcoCore.TcoTask.Done"/> properties are available.
			</para>
		</summary>
		<example>
			Declaration part of the 'TcoTask' example. 
		</example>
		<example>
			[!code-pas[Main](~/../TcOpen/src/TcoApplicationExamples/XaeAppExamples/PlcAppExamples/POUs/Task/AskForTheFavor_Task.TcPOU?name=TaskExampleDeclarations)]
		</example>
		<example>
			Implementation part of the 'TcoTask' example.
		</example>
		<example>
			[!code-pas[Main](~/../TcOpen/src/TcoApplicationExamples/XaeAppExamples/PlcAppExamples/POUs/Task/AskForTheFavor_Task.TcPOU?name=TaskBodyExampleCode)]
		</example>
		<example>
			Example of the invoking this example 'TcoTask' instance 'outside' of the instance and wait if it ends-up in 'DONE' state or in 'ERROR' state.
		</example>
		<example>
			[!code-pas[Main](~/../TcOpen/src/TcoApplicationExamples/XaeAppExamples/PlcAppExamples/POUs/Sequencer/MakeAnOfferThatCantBeRefused.TcPOU?name=TaskExternalUseExample)]
		</example>
	</docu>	
~]]></Comment><BitSize>7360</BitSize><ExtendsType Namespace="TcoCore">TcoObject</ExtendsType><Implements Namespace="TcoCore">ITcoTask</Implements><Implements Namespace="TcoCore">ITcoTaskStatus</Implements><SubItem><Name>_taskState</Name><Type Namespace="TcoCore">eTaskState</Type><BitSize>16</BitSize><BitOffs>6496</BitOffs></SubItem><SubItem><Name>_restoreRequest</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>6912</BitOffs></SubItem><SubItem><Name>_invokeRequest</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>6920</BitOffs></SubItem><SubItem><Name>_abortRequest</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>6928</BitOffs></SubItem><SubItem><Name>_enabled</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>6936</BitOffs><Default><Bool>true</Bool></Default><Properties /></SubItem><SubItem><Name>_isServiceable</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>6944</BitOffs></SubItem><SubItem><Name>_elapsedTime</Name><Type>TIME</Type><BitSize>32</BitSize><BitOffs>7200</BitOffs></SubItem><Method><Name>__getEnabled</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Gets whether the task execution is enabled.
			The task can start with <see cref="PlcDocu.TcoCore.TcoTask.Invoke()"/> method call only when this property si TRUE. 
			If the task is ```Busy``` and this property transitions to ```FALSE```, the task stops execution and enters ```Error``` state. 
		</summary>			
	</docu>	
~]]></Comment><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Local><Name>Enabled</Name><Type>BOOL</Type><BitSize>8</BitSize></Local><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>PrivateDetectExecuteCall</Name></Method><Method><Name>OnError</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Executes when task reaches the ```Error``` state.
			<para>
				Do not confuse with <see cref="PlcDocu.TcoCore.TcoTask.WhileError()"/>, that is called cyclically until '''Error''' state is left.
			</para>
		</summary>			
	</docu>	
~]]></Comment></Method><Method><Name>__getReady</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Gets whether the task is ready to be started (Tasks start by calling the <see cref="PlcDocu.TcoCore.TcoTask.Invoke()"/> method).
		</summary>			
	</docu>	
~]]></Comment><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Local><Name>Ready</Name><Type>BOOL</Type><BitSize>8</BitSize></Local><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>CheckIfAutoRestoreEnabledByParent</Name><Comment><![CDATA[~
	<docu>
		<summary>
			This method ensures reading out the parent's <see cref="PlcDocu.TcoCore.TcoState.EnableAutoRestore()/> property and writing it into the <see cref="PlcDocu.TcoCore.TcoTask.AutoRestorable()"/> of this instance.
			Calling this method is ensured by calling the implicit method <c>FB_init()</c> after download, or after online change.
		</summary>			
	</docu>	
~]]></Comment><Local><Name>_MyParent_TcoState</Name><Type Namespace="TcoCore">ITcoState</Type><BitSize>32</BitSize></Local><Properties><Property><Name>call_after_online_change_slot</Name><Value>100</Value></Property></Properties></Method><Method><Name>Restore</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Restores this instance to the Ready state. Can be called explicitly or from within one of the restore mechanisms.
			<para>
				See also <see cref="PlcDocu.TcoCore.TcoTask.AutoRestorable()"/>
			</para>
		</summary>			
	</docu>	
~]]></Comment><ReturnType Namespace="TcoCore">ITcoRestorable</ReturnType><ReturnBitSize>32</ReturnBitSize></Method><Method><Name>__getElapsedTime</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Gets the elapsed time of the execution of this task. 
			<remarks>			
				<note type="important">
					Uses `TIME` type. It might be not sutable for tasks running longer than 49 days.
				</note>
			</remarks>		
		</summary>			
	</docu>	
~]]></Comment><ReturnType>TIME</ReturnType><ReturnBitSize>32</ReturnBitSize><Local><Name>ElapsedTime</Name><Type>TIME</Type><BitSize>32</BitSize></Local><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>AutoRestore</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Private method called each time that the <see cref="PlcDocu.TcoCore.TcoTask.Execute()"/> method is called. If this instance is auto restorable, this method ensures calling the <see cref="PlcDocu.TcoCore.TcoTask.Restore()"/> method if:
			<para>
				1.)	Parent object of this instance changes its state in this Plc cycle.
			</para>
			<para>
				2.)	Parent object of this instance changes its state no mather when and this instance has not yet process this change.
			</para>
			<para>
				3.) The <see cref="PlcDocu.TcoCore.TcoTask.Invoke()"/> method has not been called for one or more cycles and starts to be called again.
			</para>
			<para>
				See also <see cref="PlcDocu.TcoCore.TcoTask.AutoRestorable()"/>
			</para>
			<para>
				See also <see cref="PlcDocu.TcoCore.TcoTask.EnableAutoRestore()"/>
			</para>
		</summary>			
	</docu>	
~]]></Comment><Local><Name>_MyParent_TcoState</Name><Type Namespace="TcoCore">ITcoState</Type><BitSize>32</BitSize></Local><Local><Name>_MyParent_ChangeStateCycle</Name><Type>ULINT</Type><BitSize>64</BitSize></Local><Local><Name>_MyParent_LastChangeState</Name><Type>INT</Type><BitSize>16</BitSize></Local></Method><Method><Name>OnAbort</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Executes when task is aborted.
		</summary>			
	</docu>	
~]]></Comment></Method><Method><Name>WhileError</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Executes until task is in ```Error``` state .
			<para>
				Do not confuse with <see cref="PlcDocu.TcoCore.TcoTask.OnError()"/>, that is called just ones when '''Error''' state is entered.
			</para>
		</summary>			
	</docu>	
~]]></Comment></Method><Method><Name>Execute</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Returns true if the task is Busy, otherwise false.
			This method needs to be called cyclically.
		</summary>			
	</docu>	
~]]></Comment><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Local><Name>_serviceableParent</Name><Type Namespace="TcoCore">ITcoServiceable</Type><BitSize>32</BitSize></Local><Local><Name>tmpTimeDiff</Name><Type>TIME</Type><BitSize>32</BitSize></Local></Method><Method><Name>Abort</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Aborts the execution of this task and restores the ready state.			
		</summary>			
	</docu>	
~]]></Comment></Method><Method><Name>OnDone</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Executes when task reaches the ```Done``` state .
		</summary>			
	</docu>	
~]]></Comment></Method><Method><Name>__getState</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Gets the actual state of this instance. 
			<para>
				See <see cref="TcoCore.eTaskState"/> for more details.
			</para>
		</summary>			
	</docu>	
~]]></Comment><ReturnType Namespace="TcoCore">eTaskState</ReturnType><ReturnBitSize>16</ReturnBitSize><Local><Name>State</Name><Type Namespace="TcoCore">eTaskState</Type><BitSize>16</BitSize></Local><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getAutoRestorable</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Gets whether this instance is auto restorable. This is depends on the parent's settings; the value of this property is given by the parent of this object. 
			This value is assigned after download by calling the implicit method <c>FB_init()</c> of the parent object and cannot be changed during runtime.
			The <c>AutoRestorable</c> property of this objects is retrieved from the <c>EnableAutoRestore</c> property of the parent object.
			This is done by calling the <c>CheckIfAutoRestoreEnabledByParent()</c> method inside the implicit method <c>FB_init()</c> after download.
			If this instance is the auto restorable it will call the <see cref="PlcDocu.TcoCore.TcoTask.Restore()"/> method if:
			<para>
				1.) The <see cref="PlcDocu.TcoCore.TcoTask.Invoke()"/> method has not been called for one or more cycles and starts to be called again.
			</para>
			<para>
				2.)	Parent object of this instance changes its state.
			</para>
			<para>
				See also <see cref="PlcDocu.TcoCore.TcoTask.EnableAutoRestore()"/>
			</para>
		</summary>			
	</docu>	
~]]></Comment><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Local><Name>AutoRestorable</Name><Type>BOOL</Type><BitSize>8</BitSize></Local><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>OnStart</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Executes ones when the task starts (at the moment of transition from the ```Requested``` state into the ```Busy``` state).
		</summary>			
	</docu>	
~]]></Comment></Method><Method><Name>__getContext</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Gets the context of this object.
			This context is given by declaration, its value is assigned after download by calling the implicit method <c>FB_init()</c> and cannot be changed during runtime.
		</summary>			
	</docu>	
~]]></Comment><ReturnType Namespace="TcoCore">ITcoContext</ReturnType><ReturnBitSize>32</ReturnBitSize><Local><Name>Context</Name><Type Namespace="TcoCore">ITcoContext</Type><BitSize>32</BitSize></Local><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__setEnabled</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Gets whether the task execution is enabled.
			The task can start with <see cref="PlcDocu.TcoCore.TcoTask.Invoke()"/> method call only when this property si TRUE. 
			If the task is ```Busy``` and this property transitions to ```FALSE```, the task stops execution and enters ```Error``` state. 
		</summary>			
	</docu>	
~]]></Comment><Parameter><Name>Enabled</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Gets whether the task execution is enabled.
			The task can start with <see cref="PlcDocu.TcoCore.TcoTask.Invoke()"/> method call only when this property si TRUE. 
			If the task is ```Busy``` and this property transitions to ```FALSE```, the task stops execution and enters ```Error``` state. 
		</summary>			
	</docu>	
~]]></Comment><Type>BOOL</Type><BitSize>8</BitSize><Properties><Property><Name>monitoring</Name><Value>variable</Value></Property></Properties></Parameter><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>ThrowWhen</Name><Comment><![CDATA[~
	<docu>
		<summary>
			When called with ```inCondition``` ```TRUE``` causes transition of the task into the ```Error``` state.
		</summary>			
	</docu>	
~]]></Comment><Parameter><Name>inCondition</Name><Type>BOOL</Type><BitSize>8</BitSize></Parameter></Method><Method><Name>__getBusy</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Gets whether the task is executing.
		</summary>			
	</docu>	
~]]></Comment><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Local><Name>Busy</Name><Type>BOOL</Type><BitSize>8</BitSize></Local><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>CheckIfCalledCyclically</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Private method called inside the <see cref="PlcDocu.TcoCore.TcoTask.Execute()"/> method checking the cyclicall calling of this method. 
			If this instance is auto restorable, this method ensures calling the <see cref="PlcDocu.TcoCore.TcoTask.Restore()"/> method if
			the <see cref="PlcDocu.TcoCore.TcoTask.Execute()"/> method has not been called for one or more cycles and starts to be called again.
			<para>
				See also <see cref="PlcDocu.TcoCore.TcoTask.AutoRestorable()"/>
			</para>
			<para>
				See also <see cref="PlcDocu.TcoCore.TcoTask.EnableAutoRestore()"/>
			</para>
		</summary>			
	</docu>	
~]]></Comment><Local><Name>_MyContextStartCycleCount</Name><Type>ULINT</Type><BitSize>64</BitSize></Local></Method><Method><Name>__getDone</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Gets whether the task has succesfully completed the  execution and did not enter into the Error state.
		</summary>			
	</docu>	
~]]></Comment><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Local><Name>Done</Name><Type>BOOL</Type><BitSize>8</BitSize></Local><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>DoneWhen</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Completes the execution of this task when ```inCondition``` is true; the task transitions into ```Done``` state.
		</summary>			
	</docu>	
~]]></Comment><Parameter><Name>inCondition</Name><Type>BOOL</Type><BitSize>8</BitSize></Parameter></Method><Method><Name>__getIdentity</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Gets identity of this <see cref ="PlcDocu.TcoCore.TcoTask()"/>. 
			This value is assigned after download by calling the implicit method <c>FB_init()</c> and cannot be changed during runtime.
			This variable is used in the higher level applications.  
		</summary>			
	</docu>	
~]]></Comment><ReturnType>ULINT</ReturnType><ReturnBitSize>64</ReturnBitSize><Local><Name>Identity</Name><Type>ULINT</Type><BitSize>64</BitSize></Local><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getError</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Returns true if the task has is in error state. To be able to start the the task again, <see cref="PlcDocu.TcoCore.TcoTask.Restore()"/> method needs to be called before 
			restarting it again calling <see cref="PlcDocu.TcoCore.TcoTask.Invoke()"/> method.
		</summary>			
	</docu>	
~]]></Comment><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Local><Name>Error</Name><Type>BOOL</Type><BitSize>8</BitSize></Local><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>Invoke</Name><Comment><![CDATA[~
	<docu>
		<summary>
			Use to start the execution of the task. The starting is possible from Ready state.
			<para>Moreover it is also possible to start the task again from Done state by performing the '''rising edge''' of the calling of the Invoke() method.</para>
			<p>Analogously to the xExecute signal of the <a href="https://plcopen.org/sites/default/files/downloads/creating_plcopen_compliant_function_block_libraries.pdf" title="Title"> PLCopen </a> motion function blocks.</p>			
		</summary>			
	</docu>	
~]]></Comment><ReturnType Namespace="TcoCore">ITcoTaskStatus</ReturnType><ReturnBitSize>32</ReturnBitSize><Local><Name>_newInvokeCall</Name><Type>BOOL</Type><BitSize>8</BitSize></Local></Method><Properties><Property><Name>PouType</Name><Value>FunctionBlock</Value></Property></Properties></DataType><DataType><Name Namespace="TcoCore.Tc2_EtherCAT">ST_EcSlaveState</Name><BitSize>16</BitSize><SubItem><Name>deviceState</Name><Type>BYTE</Type><BitSize>8</BitSize><BitOffs>0</BitOffs></SubItem><SubItem><Name>linkState</Name><Type>BYTE</Type><BitSize>8</BitSize><BitOffs>8</BitOffs></SubItem></DataType><DataType><Name Namespace="Tc2_System">T_AmsPort</Name><Comment><![CDATA[ TwinCAT AMS port address. ]]></Comment><BitSize>16</BitSize><BaseType>UINT</BaseType></DataType><DataType><Name Namespace="Tc2_System">ADSREADEX</Name><Comment><![CDATA[ Extended ADS read command. ]]></Comment><BitSize>1280</BitSize><SubItem><Name>NETID</Name><Type Namespace="Tc2_System">T_AmsNetID</Type><Comment><![CDATA[ Ams net id ]]></Comment><BitSize>192</BitSize><BitOffs>32</BitOffs><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>PORT</Name><Type Namespace="Tc2_System">T_AmsPort</Type><Comment><![CDATA[ Ads communication port ]]></Comment><BitSize>16</BitSize><BitOffs>224</BitOffs><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>IDXGRP</Name><Type>UDINT</Type><Comment><![CDATA[ Index group ]]></Comment><BitSize>32</BitSize><BitOffs>256</BitOffs><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>IDXOFFS</Name><Type>UDINT</Type><Comment><![CDATA[ Index offset ]]></Comment><BitSize>32</BitSize><BitOffs>288</BitOffs><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>LEN</Name><Type>UDINT</Type><Comment><![CDATA[ Max. number of data bytes to read (LEN <= max. 