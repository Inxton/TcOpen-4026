		<docu>
			<summary>
				Pushes the message to logging buffer.
				See also `Push`
				<note:important>
						This method is typically invoked from a `TcoMessenger`. 
						Depending on settings of the messenger the messages can be logged on rising edge of the message, to prevent buffer overrun.
						For details see `TcoMessengerSettings`.
				</note>				 
			</summary>				
		</docu>
~]]></Comment><Parameter><Name>inMessage</Name><Type Namespace="TcoCore">TcoMessage</Type><BitSize>1600</BitSize></Parameter></Method></DataType><DataType><Name Namespace="TcoCore">ITcoRtc</Name><BitSize>64</BitSize><ExtendsType GUID="{18071995-0000-0000-0000-000000000018}">PVOID</ExtendsType><Method><Name>__getIsSynchronized</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getIsValid</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>NowLocal</Name><ReturnType>DATE_AND_TIME</ReturnType><ReturnBitSize>32</ReturnBitSize></Method><Method><Name>NowLocalAsTIMESTRUCT</Name><ReturnType Namespace="Tc2_EtherCAT.Tc2_Utilities">TIMESTRUCT</ReturnType><ReturnBitSize>128</ReturnBitSize></Method><Method><Name>NowUTC</Name><ReturnType>DATE_AND_TIME</ReturnType><ReturnBitSize>32</ReturnBitSize></Method><Method><Name>NowUTCAsTIMESTRUCT</Name><ReturnType Namespace="Tc2_EtherCAT.Tc2_Utilities">TIMESTRUCT</ReturnType><ReturnBitSize>128</ReturnBitSize></Method><Method><Name>TickClock</Name><ReturnType>ULINT</ReturnType><ReturnBitSize>64</ReturnBitSize></Method></DataType><DataType><Name Namespace="TcoCore">ITcoContext</Name><BitSize>64</BitSize><ExtendsType Namespace="TcoCore">ITcoObject</ExtendsType><Method><Name>__getEndCycleCount</Name><ReturnType>ULINT</ReturnType><ReturnBitSize>64</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getEnvironment</Name><ReturnType Namespace="TcoCore">ITcoContextEnvironment</ReturnType><ReturnBitSize>64</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getLogger</Name><ReturnType Namespace="TcoCore">ITcoLogger</ReturnType><ReturnBitSize>64</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Meth